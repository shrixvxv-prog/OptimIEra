{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "OPTIMIERA_DEMO_MODE",
    "OPTIMIERA_LIVE_WRITES_ENABLED",
    "OPTIMIERA_USAGE_PAYMENTS_ENABLED",
    "OG_USAGE_PAYMENT_RECIPIENT",
    "OG_USAGE_PAYMENT_AMOUNT_WEI",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_DOCS_URL",
    "NEXT_PUBLIC_API_URL",
    "DATABASE_URL",
    "DIRECT_URL",
    "SEED_DEVELOPMENT_DATA",
    "AUTH_SECRET",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "BETTER_AUTH_TRUSTED_ORIGINS",
    "PROMPT_STORAGE_MODE",
    "OPTIMIERA_ENCRYPTION_MASTER_KEY",
    "NOUS_ENABLED",
    "NOUS_BASE_URL",
    "NOUS_API_KEY",
    "NOUS_MODEL",
    "NOUS_TIMEOUT_MS",
    "OG_COMPUTE_ENABLED",
    "OG_COMPUTE_NETWORK",
    "OG_COMPUTE_BASE_URL",
    "OG_COMPUTE_API_KEY",
    "OG_COMPUTE_MODEL",
    "OG_COMPUTE_TIMEOUT_MS",
    "OG_COMPUTE_MAX_OUTPUT_TOKENS",
    "OG_STORAGE_ENABLED",
    "OG_STORAGE_NETWORK",
    "OG_STORAGE_MODE",
    "OG_STORAGE_RPC_URL",
    "OG_STORAGE_INDEXER_URL",
    "OG_STORAGE_PRIVATE_KEY",
    "OG_STORAGE_TIMEOUT_MS",
    "OG_STORAGE_EXPECTED_REPLICA",
    "NEXT_PUBLIC_0G_STORAGE_EXPLORER_URL",
    "OG_CHAIN_ENABLED",
    "OG_CHAIN_NETWORK",
    "OG_CHAIN_RPC_URL",
    "OG_CHAIN_CHAIN_ID",
    "OG_CHAIN_EXPLORER_URL",
    "OG_CHAIN_CONFIRMATIONS",
    "OPTIMIERA_REGISTRY_ADDRESS",
    "OPTIMIERA_CHAIN_PRIVATE_KEY",
    "OPTIMIERA_DEPLOYER_PRIVATE_KEY",
    "NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID",
    "NEXT_PUBLIC_0G_NETWORK",
    "NEXT_PUBLIC_0G_CHAIN_ID",
    "NEXT_PUBLIC_0G_RPC_URL",
    "NEXT_PUBLIC_0G_EXPLORER_URL",
    "AGENTIC_ID_CONTRACT_ADDRESS",
    "OPTIMIERA_AGENT_ID",
    "OPTIMIERA_JWT_SECRET",
    "OPTIMIERA_CRON_SECRET"
  ],
  "tasks": {
    "build": { "dependsOn": ["^build"], "outputs": [".next/**", "build/**", "dist/**"] },
    "dev": { "cache": false, "persistent": true },
    "lint": { "dependsOn": ["^lint"] },
    "typecheck": { "dependsOn": ["^typecheck"] }
  }
}
