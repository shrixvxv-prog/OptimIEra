{
  "name": "@optimiera/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:migrate": "prisma migrate dev --config prisma.config.ts",
    "db:migrate:deploy": "prisma migrate deploy --config prisma.config.ts",
    "db:seed": "prisma db seed --config prisma.config.ts",
    "db:studio": "prisma studio --config prisma.config.ts",
    "db:validate": "prisma validate --config prisma.config.ts",
    "db:test:reset": "node -e \"if (!['development','test'].includes(process.env.NODE_ENV)) process.exit(1)\" && prisma migrate reset --force --config prisma.config.ts",
    "db:reencrypt:local": "tsx prisma/reencrypt-local.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --ignore-pattern src/generated --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@optimiera/encryption": "workspace:*",
    "@optimiera/optimizer-core": "workspace:*",
    "@optimiera/schemas": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@types/pg": "^8.20.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "tsx": "^4.23.1"
  }
}
